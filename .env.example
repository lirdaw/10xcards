# Copy to .env and fill in. Never commit real secrets — .env is gitignored.
#
# Local values: run `npm run db:start`, then `npx supabase status` and copy
# "Project URL" and the "Publishable" key from its output.
#
# SUPABASE_KEY must be the publishable (anon) key, never the secret/service_role key:
# a secret key bypasses RLS, and RLS is the only thing isolating accounts in this app.
# The test preflight (tests/setup/preflight.ts) refuses to run if you get this wrong.
SUPABASE_URL=
SUPABASE_KEY=

# Flashcard generation via OpenRouter. Unset locally = the generator falls back to mock
# mode; on production a missing key means mock cards ship silently, so set it there via
# `wrangler secret put OPENROUTER_API_KEY` and verify a real generation after deploy.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
