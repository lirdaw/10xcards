---
interface Props {
  activeItem?: "decks" | "generate" | "study";
}

const { activeItem = "decks" } = Astro.props;

// Each item carries its lucide-style icon as a list of path `d` strings, rendered
// to the left of the label — and the only thing visible when the rail is collapsed.
const items = [
  {
    key: "decks",
    label: "Talie",
    href: "/decks",
    enabled: true,
    icon: ["M12 2 21 7 12 12 3 7Z", "m3 12 9 5 9-5", "m3 17 9 5 9-5"],
  },
  {
    key: "generate",
    label: "Generuj fiszki",
    href: null,
    enabled: false,
    icon: ["M12 3l1.8 6.2L20 11l-6.2 1.8L12 19l-1.8-6.2L4 11l6.2-1.8z"],
  },
  {
    key: "study",
    label: "Nauka",
    href: null,
    enabled: false,
    icon: ["M4 19.5A2.5 2.5 0 0 1 6.5 17H20", "M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"],
  },
] as const;
---

<aside
  id="app-sidebar"
  data-collapsed="false"
  class="my-4 ml-4 flex w-60 shrink-0 flex-col rounded-2xl border border-white/10 bg-white/5 text-white backdrop-blur-xl"
>
  <div class="sidebar-header flex items-center justify-between gap-2 px-4 py-5">
    <a
      href="/decks"
      class="sidebar-label bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold tracking-tight text-transparent"
      >10xCards</a
    >
    <button
      id="sidebar-toggle"
      type="button"
      aria-label="Zwiń lub rozwiń menu"
      aria-controls="app-sidebar"
      aria-expanded="true"
      class="shrink-0 rounded-lg p-1.5 text-blue-100/70 transition-colors hover:bg-white/10 hover:text-white"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>
  <nav aria-label="Główna nawigacja" class="flex flex-col gap-1 px-3">
    {
      items.map((item) =>
        item.enabled ? (
          <a
            href={item.href}
            title={item.label}
            aria-current={activeItem === item.key ? "page" : undefined}
            class:list={[
              "sidebar-item flex items-center gap-3 rounded-lg px-3 py-2 text-base font-medium transition-colors",
              activeItem === item.key
                ? "bg-white/15 text-white"
                : "text-blue-100/70 hover:bg-white/10 hover:text-white",
            ]}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="shrink-0"
            >
              {item.icon.map((d) => (
                <path d={d} />
              ))}
            </svg>
            <span class="sidebar-label whitespace-nowrap">{item.label}</span>
          </a>
        ) : (
          <span
            aria-disabled="true"
            tabindex="-1"
            title="Dostępne wkrótce"
            class="sidebar-item flex cursor-not-allowed items-center gap-3 rounded-lg px-3 py-2 text-base font-medium text-blue-100/40 select-none"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="shrink-0"
            >
              {item.icon.map((d) => (
                <path d={d} />
              ))}
            </svg>
            <span class="sidebar-label whitespace-nowrap">{item.label}</span>
          </span>
        ),
      )
    }
  </nav>
</aside>

<script is:inline>
  (() => {
    const KEY = "sidebar-collapsed";
    const sidebar = document.getElementById("app-sidebar");
    const toggle = document.getElementById("sidebar-toggle");
    if (!sidebar || !toggle) return;

    const header = sidebar.querySelector(".sidebar-header");
    const labels = sidebar.querySelectorAll(".sidebar-label");
    const navItems = sidebar.querySelectorAll(".sidebar-item");

    // Drive everything through inline styles (no CSS-cascade/layer dependence), so
    // the collapsed rail is 100% deterministic: narrow to an icon-only strip, hide
    // the wordmark + labels, and centre each icon.
    const apply = (collapsed) => {
      sidebar.setAttribute("data-collapsed", String(collapsed));
      toggle.setAttribute("aria-expanded", String(!collapsed));
      sidebar.style.width = collapsed ? "4rem" : "15rem";
      if (header) header.style.justifyContent = collapsed ? "center" : "";
      labels.forEach((el) => {
        el.style.display = collapsed ? "none" : "";
      });
      navItems.forEach((el) => {
        el.style.justifyContent = collapsed ? "center" : "";
        el.style.paddingLeft = collapsed ? "0" : "";
        el.style.paddingRight = collapsed ? "0" : "";
      });
    };

    // Restore persisted state synchronously (before first paint) so navigating
    // between pages never flashes or animates the rail.
    apply(localStorage.getItem(KEY) === "true");

    // Enable the width animation only AFTER the initial state is painted, so page
    // loads stay instant and only a user toggle animates.
    requestAnimationFrame(() => {
      sidebar.style.transition = "width 200ms ease-out";
    });

    toggle.addEventListener("click", () => {
      const next = sidebar.getAttribute("data-collapsed") !== "true";
      localStorage.setItem(KEY, String(next));
      apply(next);
    });
  })();
</script>
