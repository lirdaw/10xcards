---
import Layout from "@/layouts/Layout.astro";
import Sidebar from "@/components/Sidebar.astro";

interface Props {
  title?: string;
  activeItem?: "decks" | "generate" | "study";
}

const { title, activeItem = "decks" } = Astro.props;
const { user } = Astro.locals;
---

<Layout title={title}>
  <div class="bg-cosmic flex h-screen overflow-hidden text-white">
    <Sidebar activeItem={activeItem} />
    <div class="flex min-w-0 flex-1 flex-col">
      <header
        class="mt-4 mr-4 flex items-center justify-between rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-base"
      >
        <span class="text-blue-100/70">{user?.email}</span>
        <form method="POST" action="/api/auth/signout">
          <button type="submit" class="text-purple-300 transition-colors hover:text-purple-100 hover:underline">
            Wyloguj
          </button>
        </form>
      </header>
      {
        /* `main` is the scroll container (shell is locked to the viewport height),
          so the sidebar and header stay put and the content scrolls with the
          cosmic-themed custom-scrollbar instead of the default viewport bar. */
      }
      <main class="custom-scrollbar flex-1 overflow-x-hidden overflow-y-auto px-8 py-8">
        <slot />
      </main>
    </div>
  </div>
</Layout>
